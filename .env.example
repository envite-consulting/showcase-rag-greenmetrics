# Runtime paths inside the rag-app container
DATA_DIR=/src/data/raw
INDEX_DIR=/src/data/index
EMBED_DIR=/emb_models
LOG_DIR=/logs
HF_HOME=/root/.cache/huggingface

# RAG configuration
CHUNKING_STRATEGY=simple
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
NORMALIZE_EMBEDDINGS=True
HNSW_EF_CONSTRUCTION=100
HNSW_EF_SEARCH=100
HNSW_MAX_NEIGHBORS=16
TOP_K=5
METADATA_FILTER=False
METADATA_ENHANCEMENT=False
POST_BM25_RERANK=False
SIMILARITY_THRESHOLD=3.0

# Ollama / generation
LLM_HOST=http://ollama:11434
OLLAMA_MODEL=llama3:8b
TEMPERATURE=0.0
MAX_TOKENS=512

# Showcase load
RAG_API_URL=http://127.0.0.1:8000/ask
RAG_QUESTIONS_PATH=/src/scripts/questions.json
RAG_QUESTION_LIMIT=8
RAG_PRINT_RESPONSES=0

# Misc
ANONYMIZED_TELEMETRY=False
LOG_LEVEL=INFO
